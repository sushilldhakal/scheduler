{
  "name": "@shadcn-scheduler/view-list",
  "version": "0.1.0",
  "description": "List view component for shadcn-scheduler",
  "type": "module",
  "main": "../../dist/view-list/index.cjs",
  "module": "../../dist/view-list/index.js",
  "types": "../../dist/view-list/index.d.ts",
  "sideEffects": false,
  "files": [
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "../../dist/view-list/index.d.ts",
      "import": "../../dist/view-list/index.js",
      "require": "../../dist/view-list/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf ../../dist/view-list"
  },
  "keywords": [
    "scheduler",
    "list-view",
    "calendar",
    "react"
  ],
  "author": "Sushil Dhakal",
  "license": "MIT",
  "peerDependencies": {
    "@shadcn-scheduler/core": "*",
    "@shadcn-scheduler/shell": "*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
