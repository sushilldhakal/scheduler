{
  "name": "@shadcn-scheduler/core",
  "version": "0.1.0",
  "description": "Headless core engine for shadcn-scheduler with zero React dependencies",
  "type": "module",
  "main": "../../dist/core/index.cjs",
  "module": "../../dist/core/index.js",
  "types": "../../dist/core/index.d.ts",
  "sideEffects": false,
  "files": [
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "../../dist/core/index.d.ts",
      "import": "../../dist/core/index.js",
      "require": "../../dist/core/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf ../../dist/core"
  },
  "keywords": [
    "scheduler",
    "headless",
    "core",
    "calendar",
    "layout",
    "algorithms"
  ],
  "author": "Sushil Dhakal",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
